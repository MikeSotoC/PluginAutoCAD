<Window x:Class="CatastroUrbano.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Catastro Urbano v1.0" 
        Height="550" 
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Segoe UI"
        FontSize="14">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- TabControl Principal -->
        <TabControl Grid.Row="0" 
                    Name="mainTabControl"
                    Margin="0">
            
            <!-- Pestaña DIBUJO -->
            <TabItem Header="Dibujo" Height="25">
                <Grid Background="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <GroupBox Header="Herramientas" 
                                      BorderBrush="#CCCCCC"
                                      BorderThickness="1"
                                      Padding="10"
                                      Margin="0,0,0,10">
                                <StackPanel>
                                    <Button Content="📍 Lote"
                                            Height="35"
                                            Background="#0078D7"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,0,8"
                                            ToolTip="Dibujar lote"
                                            Click="BtnLote_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1E90FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Button Content="🏘 Manzana"
                                            Height="35"
                                            Background="#0078D7"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,0,8"
                                            ToolTip="Dibujar manzana"
                                            Click="BtnManzana_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1E90FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Button Content="🏢 Construcción"
                                            Height="35"
                                            Background="#0078D7"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,0,8"
                                            ToolTip="Dibujar construcción"
                                            Click="BtnConstruccion_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1E90FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Button Content="✏ Editar"
                                            Height="35"
                                            Background="#FF8C00"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,0,8"
                                            ToolTip="Editar elemento"
                                            Click="BtnEditar_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FFA500"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Button Content="🗑 Eliminar"
                                            Height="35"
                                            Background="#DC3545"
                                            Foreground="White"
                                            BorderThickness="0"
                                            ToolTip="Eliminar elemento"
                                            Click="BtnEliminar_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E04050"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <!-- Pestaña ANÁLISIS -->
            <TabItem Header="Análisis" Height="25">
                <Grid Background="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <GroupBox Header="Análisis Geométrico" 
                                      BorderBrush="#CCCCCC"
                                      BorderThickness="1"
                                      Padding="10"
                                      Margin="0,0,0,10">
                                <StackPanel>
                                    <Button Content="📐 Área"
                                            Height="35"
                                            Background="#28A745"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,0,8"
                                            ToolTip="Calcular área"
                                            Click="BtnArea_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3CB850"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Button Content="📏 Perímetro"
                                            Height="35"
                                            Background="#28A745"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,0,8"
                                            ToolTip="Calcular perímetro"
                                            Click="BtnPerimetro_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3CB850"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Button Content="✓ Validar"
                                            Height="35"
                                            Background="#FFC107"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,0,8"
                                            ToolTip="Validar geometría"
                                            Click="BtnValidar_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FFD54F"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Button Content="🔍 Superposiciones"
                                            Height="35"
                                            Background="#DC3545"
                                            Foreground="White"
                                            BorderThickness="0"
                                            ToolTip="Detectar superposiciones"
                                            Click="BtnSuperposicion_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E04050"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <!-- Pestaña CLASIFICACIÓN -->
            <TabItem Header="Clasificación" Height="25">
                <Grid Background="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <GroupBox Header="Clasificación de Uso" 
                                      BorderBrush="#CCCCCC"
                                      BorderThickness="1"
                                      Padding="10"
                                      Margin="0,0,0,10">
                                <StackPanel>
                                    <Label Content="Tipo de Uso:" 
                                           FontWeight="Normal"
                                           Margin="0,0,0,5"/>
                                    
                                    <ComboBox Name="cmbTipoUso"
                                              Height="30"
                                              Margin="0,0,0,15"
                                              FontSize="14">
                                        <ComboBoxItem Content="Residencial" IsSelected="True"/>
                                        <ComboBoxItem Content="Comercial"/>
                                        <ComboBoxItem Content="Industrial"/>
                                        <ComboBoxItem Content="Mixto"/>
                                        <ComboBoxItem Content="Equipamiento"/>
                                        <ComboBoxItem Content="Espacio Público"/>
                                        <ComboBoxItem Content="Agrícola"/>
                                        <ComboBoxItem Content="Otros"/>
                                    </ComboBox>
                                    
                                    <Button Content="🏷 Clasificar"
                                            Height="35"
                                            Background="#0078D7"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,0,15"
                                            ToolTip="Aplicar clasificación"
                                            Click="BtnClasificar_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1E90FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Label Content="Resultados:" 
                                           FontWeight="Normal"
                                           Margin="0,0,0,5"/>
                                    
                                    <ListBox Name="lstResultados"
                                             Height="100"
                                             BorderBrush="#CCCCCC"
                                             BorderThickness="1"
                                             Margin="0,0,0,5"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <!-- Pestaña TABLAS -->
            <TabItem Header="Tablas" Height="25">
                <Grid Background="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <GroupBox Header="Generación de Tablas" 
                                      BorderBrush="#CCCCCC"
                                      BorderThickness="1"
                                      Padding="10"
                                      Margin="0,0,0,10">
                                <StackPanel>
                                    <Button Content="📊 Tabla Catastral"
                                            Height="35"
                                            Background="#0078D7"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,0,8"
                                            ToolTip="Generar tabla catastral"
                                            Click="BtnGenerarCatastro_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1E90FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Button Content="📈 Exportar Excel"
                                            Height="35"
                                            Background="#28A745"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,0,8"
                                            ToolTip="Exportar a Excel"
                                            Click="BtnExportarExcel_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3CB850"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Button Content="📄 Reporte"
                                            Height="35"
                                            Background="#6C757D"
                                            Foreground="White"
                                            BorderThickness="0"
                                            ToolTip="Generar reporte PDF"
                                            Click="BtnReporte_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#7D8A8F"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- StatusBar -->
        <StatusBar Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            
            <StatusBarItem Grid.Column="0">
                <TextBlock Name="lblEstado" Text="Listo"/>
            </StatusBarItem>
            
            <StatusBarItem Grid.Column="1">
                <ProgressBar Name="progressBar" 
                             Width="100" 
                             Height="16" 
                             Visibility="Collapsed"
                             Minimum="0" 
                             Maximum="100"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
